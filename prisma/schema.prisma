generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  employee
}

enum AccountStatus {
  active
  disabled
}

enum ProductCategory {
  tobacco
  beverages
  snacks
  candy
  grocery
  foodservice
  lottery
  fuel
  other
}

enum TransactionType {
  sale
  refund
  void
}

enum PaymentMethod {
  cash
  credit
  debit
  mobile
}

enum PurchaseOrderStatus {
  draft
  submitted
  received
  cancelled
}

enum FuelGrade {
  regular
  midgrade
  premium
  diesel
}

enum ShrinkageCategory {
  theft
  damage
  spoilage
  vendor_error
  unknown
}

enum FoodserviceCategory {
  roller_grill
  pizza
  chicken
  sides
  taquitos
  tacos
  beverages
  other
}

enum FoodserviceBrand {
  store_brand
  hatch
}

enum FoodserviceWasteReason {
  expired_hold
  dropped
  overproduction
  quality_issue
  other
}

enum FoodserviceHotCaseStatus {
  active
  sold
  wasted
}

enum ProductionPlanStatus {
  draft
  confirmed
}

enum NotificationSeverity {
  info
  warning
  critical
}

enum NotificationCategory {
  low_stock
  void_alert
  delivery
  audit
  shrinkage
  system
  fuel_tank
  foodservice
}

model Store {
  id        String   @id
  name      String
  location  String?
  /// When true, Hatch-branded menu items and recipes are available at this location.
  hatchEnabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  inventory          Inventory[]
  posTransactions    PosTransaction[]
  purchaseOrders     PurchaseOrder[]
  fuelData           FuelData[]
  auditLogs          AuditLog[]
  shrinkageRecords   ShrinkageRecord[]
  notifications      Notification[]
  productPriceOverrides StoreProductPriceOverride[]
  shifts             Shift[]
  shiftTemplates     ShiftTemplate[]
  fuelDeliveries     FuelDelivery[]
  foodserviceMenuItems   FoodserviceMenuItem[]
  foodserviceHotCase     FoodserviceHotCaseEntry[]
  foodserviceWasteLogs   FoodserviceWasteLog[]
  productionPlans        ProductionPlan[]
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  passwordHash         String
  firstName            String
  lastName             String
  role                 UserRole
  assignedStoreId      String?
  assignedStore        Store?        @relation(fields: [assignedStoreId], references: [id])
  accountStatus        AccountStatus @default(active)
  mfaEnabled           Boolean       @default(false)
  mfaSecret            String?
  forcePasswordChange  Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  lastLoginAt          DateTime?

  loginAttempts          LoginAttempt[]
  processedTransactions  PosTransaction[]   @relation("TransactionCashier")
  orderedPurchaseOrders  PurchaseOrder[]    @relation("PurchaseOrderOrderedBy")
  auditLogs              AuditLog[]
  notifications          Notification[]           @relation("NotificationRecipient")
  notificationPreference UserNotificationPreference?
  productChangeLogs      ProductChangeLog[]
  shiftsAsEmployee       Shift[]                  @relation("ShiftEmployee")
  shiftsCreated          Shift[]                  @relation("ShiftCreatedBy")
  shiftTemplatesCreated  ShiftTemplate[]
  fuelDeliveriesLogged   FuelDelivery[]         @relation("FuelDeliveryLogger")
  fuelPriceChanges       FuelPriceHistory[]
  foodserviceWasteLogs   FoodserviceWasteLog[]
  hotCasePlaced          FoodserviceHotCaseEntry[] @relation("HotCasePlacedBy")
  hotCaseDisposed        FoodserviceHotCaseEntry[] @relation("HotCaseDisposedBy")
  productionPlansConfirmed ProductionPlan[]      @relation("ProductionPlanConfirmedBy")
}

/// One scheduled work block per employee per calendar day at a store (start/end as minutes from midnight; if end <= start, shift crosses midnight).
model Shift {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     User     @relation("ShiftEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  shiftDate    DateTime @db.Date
  startMinutes Int
  endMinutes   Int
  templateName String?
  notes        String?  @db.Text
  createdById  String
  createdBy    User     @relation("ShiftCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([storeId, employeeId, shiftDate])
  @@index([storeId, shiftDate])
  @@index([employeeId])
}

model ShiftTemplate {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  startMinutes Int
  endMinutes   Int
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([storeId, name])
  @@index([storeId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  ipAddress String
  mfaUsed   Boolean
  success   Boolean

  @@index([createdAt])
}

model Vendor {
  id             String   @id @default(cuid())
  companyName    String
  contactName    String
  contactEmail   String
  contactPhone   String
  accountNumber  String
  paymentTerms   String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([companyName])
}

model Product {
  id           String          @id @default(cuid())
  upc          String          @unique
  name         String
  description  String?
  category     ProductCategory
  brand        String?
  vendorId     String
  vendor       Vendor          @relation(fields: [vendorId], references: [id])
  costPrice    Decimal         @db.Decimal(12, 2)
  retailPrice  Decimal         @db.Decimal(12, 2)
  taxEligible  Boolean         @default(true)
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  inventory              Inventory[]
  transactionLineItems   TransactionLineItem[]
  purchaseOrderLineItems PurchaseOrderLineItem[]
  auditLogs              AuditLog[]
  shrinkageRecords       ShrinkageRecord[]
  storePriceOverrides    StoreProductPriceOverride[]
  changeLogs             ProductChangeLog[]
  recipeIngredients      RecipeIngredient[]

  @@index([vendorId])
}

/// Per-store retail price override; falls back to Product.retailPrice when absent.
model StoreProductPriceOverride {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  retailPrice Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, productId])
  @@index([productId])
}

model ProductChangeLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id], onDelete: Cascade)
  fieldKey    String
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([productId, createdAt(sort: Desc)])
}

model Inventory {
  id                 String    @id @default(cuid())
  storeId            String
  store              Store     @relation(fields: [storeId], references: [id])
  productId          String
  product            Product   @relation(fields: [productId], references: [id])
  quantityOnHand     Int
  minStockThreshold  Int
  lastCountedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([storeId, productId])
  @@index([storeId])
  @@index([productId])
}

/// Point-of-sale transaction (maps to table `transactions`).
model PosTransaction {
  id                    String          @id @default(cuid())
  storeId               String
  store                 Store           @relation(fields: [storeId], references: [id])
  terminalId            String
  type                  TransactionType
  subtotal              Decimal         @db.Decimal(12, 2)
  taxAmount             Decimal         @db.Decimal(12, 2)
  total                 Decimal         @db.Decimal(12, 2)
  paymentMethod         PaymentMethod
  verifoneReferenceId   String?         @unique
  employeeId            String
  employee              User            @relation("TransactionCashier", fields: [employeeId], references: [id])
  transactionAt         DateTime
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  lineItems TransactionLineItem[]

  @@index([storeId])
  @@index([transactionAt])
  @@map("transactions")
}

model TransactionLineItem {
  id             String         @id @default(cuid())
  transactionId  String
  transaction    PosTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId      String
  product        Product        @relation(fields: [productId], references: [id])
  quantity       Int
  unitPrice      Decimal        @db.Decimal(12, 2)
  lineTotal      Decimal        @db.Decimal(12, 2)
  discountAmount Decimal        @default(0) @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([transactionId])
  @@index([productId])
}

model PurchaseOrder {
  id                   String               @id @default(cuid())
  storeId              String
  store                Store                @relation(fields: [storeId], references: [id])
  vendorId             String
  vendor               Vendor               @relation(fields: [vendorId], references: [id])
  status               PurchaseOrderStatus
  orderedByEmployeeId  String
  orderedBy            User                 @relation("PurchaseOrderOrderedBy", fields: [orderedByEmployeeId], references: [id])
  dateOrdered          DateTime
  dateReceived         DateTime?
  totalCost            Decimal              @db.Decimal(12, 2)
  notes                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  lineItems PurchaseOrderLineItem[]

  @@index([storeId])
  @@index([vendorId])
}

model PurchaseOrderLineItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantityOrdered  Int
  quantityReceived Int
  unitCost         Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([purchaseOrderId])
  @@index([productId])
}

model FuelData {
  id                         String    @id @default(cuid())
  storeId                    String
  store                      Store     @relation(fields: [storeId], references: [id])
  tankNumber                 Int
  grade                      FuelGrade
  currentVolumeGallons       Decimal   @db.Decimal(12, 3)
  tankCapacityGallons        Decimal   @db.Decimal(12, 3)
  lastDeliveryDate           DateTime?
  lastDeliveryVolumeGallons  Decimal?  @db.Decimal(12, 3)
  currentRetailPricePerGallon Decimal  @db.Decimal(12, 3)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  deliveries     FuelDelivery[]
  priceHistory   FuelPriceHistory[]
  dailySnapshots FuelDailyVolumeSnapshot[]

  @@unique([storeId, tankNumber])
  @@index([storeId])
}

model FuelDelivery {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fuelDataId    String
  tank          FuelData @relation(fields: [fuelDataId], references: [id], onDelete: Cascade)
  volumeGallons Decimal  @db.Decimal(12, 3)
  deliveryDate  DateTime @db.Date
  notes         String?  @db.Text
  loggedById    String
  loggedBy      User     @relation("FuelDeliveryLogger", fields: [loggedById], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeId, deliveryDate(sort: Desc)])
  @@index([fuelDataId])
}

model FuelPriceHistory {
  id                String   @id @default(cuid())
  fuelDataId        String
  tank              FuelData @relation(fields: [fuelDataId], references: [id], onDelete: Cascade)
  oldPricePerGallon Decimal  @db.Decimal(12, 3)
  newPricePerGallon Decimal  @db.Decimal(12, 3)
  changedById       String
  changedBy         User     @relation(fields: [changedById], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([fuelDataId, createdAt(sort: Desc)])
}

/// End-of-day style reading per tank for sales estimates (updated when the fuel dashboard is loaded or after deliveries).
model FuelDailyVolumeSnapshot {
  id            String   @id @default(cuid())
  fuelDataId    String
  tank          FuelData @relation(fields: [fuelDataId], references: [id], onDelete: Cascade)
  snapshotDate  DateTime @db.Date
  volumeGallons Decimal  @db.Decimal(12, 3)
  createdAt     DateTime @default(now())

  @@unique([fuelDataId, snapshotDate])
  @@index([snapshotDate])
}

model Recipe {
  id               String               @id @default(cuid())
  name             String
  brand            FoodserviceBrand
  category         FoodserviceCategory
  instructions     String               @db.Text
  prepTimeMinutes  Int
  cookTimeMinutes  Int
  cookTemperature  String?
  yieldQuantity    Decimal              @db.Decimal(12, 3)
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  ingredients   RecipeIngredient[]
  menuItems     FoodserviceMenuItem[]
}

model RecipeIngredient {
  id               String   @id @default(cuid())
  recipeId         String
  recipe           Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantityPerBatch Decimal  @db.Decimal(14, 4)
  unitOfMeasure    String
  createdAt        DateTime @default(now())

  @@index([recipeId])
  @@index([productId])
}

model FoodserviceMenuItem {
  id               String               @id @default(cuid())
  storeId          String
  store            Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  itemName         String
  category         FoodserviceCategory
  brand            FoodserviceBrand
  recipeId         String?
  recipe           Recipe?              @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  retailPrice      Decimal              @db.Decimal(12, 2)
  active           Boolean              @default(true)
  holdTimeMinutes  Int
  prepTimeMinutes  Int
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  hotCaseEntries   FoodserviceHotCaseEntry[]
  wasteLogs        FoodserviceWasteLog[]
  productionLines  ProductionPlanLine[]

  @@index([storeId, active])
}

model FoodserviceHotCaseEntry {
  id             String                   @id @default(cuid())
  storeId        String
  store          Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuItemId     String
  menuItem       FoodserviceMenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantityPlaced Int
  placedAt       DateTime                 @default(now())
  expiresAt      DateTime
  status         FoodserviceHotCaseStatus @default(active)
  placedById     String
  placedBy       User                     @relation("HotCasePlacedBy", fields: [placedById], references: [id], onDelete: Cascade)
  disposedAt     DateTime?
  disposedById   String?
  disposedBy     User?                    @relation("HotCaseDisposedBy", fields: [disposedById], references: [id], onDelete: SetNull)
  wasteLogs      FoodserviceWasteLog[]

  @@index([storeId, status, expiresAt])
  @@index([menuItemId])
}

model FoodserviceWasteLog {
  id             String                 @id @default(cuid())
  storeId        String
  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuItemId     String
  menuItem       FoodserviceMenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity       Int
  reason         FoodserviceWasteReason
  loggedById     String
  loggedBy       User                   @relation(fields: [loggedById], references: [id], onDelete: Cascade)
  hotCaseEntryId String?
  hotCaseEntry   FoodserviceHotCaseEntry? @relation(fields: [hotCaseEntryId], references: [id], onDelete: SetNull)
  createdAt      DateTime               @default(now())

  @@index([storeId, createdAt(sort: Desc)])
  @@index([menuItemId])
}

model ProductionPlan {
  id              String               @id @default(cuid())
  storeId         String
  store           Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  planDate        DateTime             @db.Date
  status          ProductionPlanStatus @default(draft)
  confirmedAt     DateTime?
  confirmedById   String?
  confirmedBy     User?                @relation("ProductionPlanConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  lines ProductionPlanLine[]

  @@unique([storeId, planDate])
}

model ProductionPlanLine {
  id                String              @id @default(cuid())
  planId            String
  plan              ProductionPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  menuItemId        String
  menuItem          FoodserviceMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantitySuggested Int
  quantityFinal     Int
  createdAt         DateTime            @default(now())

  @@index([planId])
}

model AuditLog {
  id                String   @id @default(cuid())
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id])
  employeeId        String
  employee          User     @relation(fields: [employeeId], references: [id])
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  systemQuantity    Int
  countedQuantity   Int
  discrepancyAmount Int
  auditedAt         DateTime
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([storeId])
  @@index([productId])
  @@index([auditedAt])
}

model ShrinkageRecord {
  id                  String             @id @default(cuid())
  storeId             String
  store               Store              @relation(fields: [storeId], references: [id])
  productId           String
  product             Product            @relation(fields: [productId], references: [id])
  quantityLost        Int
  estimatedLossValue  Decimal            @db.Decimal(12, 2)
  periodStart         DateTime           @db.Date
  periodEnd           DateTime           @db.Date
  category            ShrinkageCategory
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([storeId])
  @@index([productId])
}

/// In-app alert for a specific user (per-user read state).
model Notification {
  id               String               @id @default(cuid())
  storeId          String?
  store            Store?               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipientUserId  String
  recipient        User                 @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  title            String
  description      String               @db.Text
  severity         NotificationSeverity
  category         NotificationCategory
  linkUrl          String
  read             Boolean              @default(false)
  /// Idempotency key for automated checks; scoped per recipient in application logic.
  dedupeKey        String?
  createdAt        DateTime             @default(now())

  @@index([recipientUserId, dedupeKey])
  @@index([recipientUserId, read, createdAt(sort: Desc)])
  @@index([storeId, createdAt])
  @@index([createdAt])
}

model UserNotificationPreference {
  userId        String  @id
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lowStock      Boolean @default(true)
  voidAlert     Boolean @default(true)
  delivery      Boolean @default(true)
  auditReminder Boolean @default(true)
  shrinkage     Boolean @default(true)
  system        Boolean @default(true)
  fuelTank      Boolean @default(true)
  foodservice   Boolean @default(true)
  updatedAt     DateTime @updatedAt
}
