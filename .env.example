# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/rdi?sslmode=require"

# Auth (JWT)
JWT_SECRET="change-me-please-use-a-long-random-string"
SESSION_COOKIE_NAME="rdi_session"
MFA_PENDING_COOKIE_NAME="rdi_mfa_pending"
JWT_ISSUER="rdi"
JWT_AUDIENCE="rdi_web"
JWT_SESSION_TTL_SECONDS="86400"
JWT_MFA_PENDING_TTL_SECONDS="600"

# Security
BCRYPT_SALT_ROUNDS="12"

# Seed passwords
TEMP_ADMIN_PASSWORD="TempAdminPassword_ChangeMe123!"
SEED_USER_PASSWORD="TempUserPassword_ChangeMe123!"

# App base
APP_BASE_URL="http://localhost:3000"

